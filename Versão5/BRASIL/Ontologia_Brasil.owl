ObjectProperty: bim:p.suportar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.baldrame
	SubPropertyOf: bim:p.suportar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a suportar: é.baldrame"@pt
	Annotations: bim:Chave "d.supor.104"
	Annotations: bim:Ação "Ação de suportar"@pt
	Annotations: bim:Definição "Declara que o objeto é apto para usar como fundação estrutural rasa e contínua de concreto armado, usada para distribuir o peso de uma estrutura diretamente ao solo. Também denominada cinta."@pt
	Annotations: bim:Definición "Declara que el objeto es adecuado para su uso como una base estructural superficial y continua de hormigón armado, utilizada para distribuir el peso de una estructura directamente al suelo. También llamado faja."@es
	Annotations: bim:Definition "It declares that the object is suitable for use as a shallow and continuous structural foundation of reinforced concrete, used to distribute the weight of a structure directly to the ground. Also called girdle."@en
	Annotations: bim:CatRevit "[ OST_StructuralFoundation ]"
	Annotations: bim:ClasseIfc "[ IfcFooting ]"
	EquivalentTo: bim:é.sapata.corrida

