bim:Gramínea rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Flora ;
      rdfs:label  "Gramínea"@pt ;
      bim:Definição   "Planta geralmente herbácea, com folhas estreitas, caules ocos e flores agrupadas em espiguetas."@pt ;
      bim:Definición  "Plantas generalmente herbáceas, con hojas estrechas, tallos huecos y flores agrupadas en espiguillas."@es ;
       bim:Definition  "Usually herbaceous plant, with narrow leaves, hollow stems and flowers grouped in spikelets."@en ;
