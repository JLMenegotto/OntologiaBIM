bim:Subarbusto rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Flora ;
      rdfs:label  "Subarbusto"@pt ;
      bim:Definição   "Planta que combina características de arbustos e herbáceas. Geralmente com altura inferior a 1 metro. Possui base lenhosa (como um arbusto), mas seus ramos superiores são mais frágeis e podem ser herbáceos. Muitas espécies são perenes, mas os ramos mais altos podem morrer e se renovar periodicamente. Alguns exemplos de subarbustos são a Lavanda e o tomilho."@pt ;
      bim:Definición  "Planta que combina características de arbustos y plantas herbáceas. Normalmente con una altura inferior a 1 metro. Tiene una base leñosa (como un arbusto), pero sus ramas superiores son más frágiles y pueden ser herbáceas. Muchas especies son perennes, pero las ramas más altas pueden morir y renovarse periódicamente. Ejemplos: lavanda, tomillo y romero."@es ;
       bim:Definition  "Plant that combines characteristics of shrubs and herbaceous plants. Usually with a height of less than 1 meter. It has a woody base (like a shrub), but its upper branches are more fragile and can be herbaceous. Many species are perennials, but the taller branches can die and periodically renew themselves. Some examples of subshrubs are Lavender and Thyme."@en ;
      bim:Natureza    "Reinos"@pt ;
      bim:Espécie     "Vegetal"@pt ;
      bim:Tema        "Flora"@pt ;
      bim:Disciplina  "Paisagística"@pt ;
      bim:Chave       "Key-PAI-9"@pt ;
      bim:CatRevit    "[ OST_Planting ]"   ;
      bim:ClasseIfc   "[ IfcGeographicElement ]"   ;
      bim:ABNT        "[ 3E.02.12 ]"    .


