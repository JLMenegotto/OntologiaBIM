Class: bim:Aeroporto.Internacional
	Annotations: rdfs:label "Aeroporto.Internacional"@pt
	Annotations: bim:Definição "Aeroporto Internacional deve ter infraestrutura para voos internacionais, com alfândega, imigração e controle sanitário."@pt
	Annotations: bim:Definición "El Aeropuerto Internacional debe contar con infraestructura para vuelos internacionales, con control aduanero, migratorio y sanitario."@es
	Annotations: bim:Definition "International Airport must have infrastructure for international flights, with customs, immigration and sanitary control."@en
