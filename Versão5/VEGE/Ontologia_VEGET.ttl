     bim:é.código.de.conservação    bim:Pouco.Preocupante ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:nome.científico    "Salix viminalis" ;
     bim:tipo.botânico    "Arbóreo" ;
     bim:diâmetro.do.tronco   0 ;
     bim:diâmetro.mínimo.da.copa   0 ;
     bim:diâmetro.máximo.da.copa   0 ;
     bim:altura.mínima.da.planta   7 ;
     bim:altura.máxima.da.planta   10 ;
     bim:tipo.de.raiz    "Fascicular (cabeleira)" ;
     bim:profundidade.da.raiz    "1.0" ;
     bim:tempo.de.crescimento    "5 anos" ;
     bim:longevidade.da.planta    "50 anos" ;
     bim:usada.para    "Biomassa, cestaria, restauração ambiental e fixação de margens de rios" ;
     bim:descrição    "Arbusto ou árvore pequena, geralmente entre 3 e 7 metros de altura. Pode atingir até 10 metros em condições ideais. Folhas: Longas, estreitas e lanceoladas, com margens finamente serrilhadas. Superfície superior verde-escura e inferior esbranquiçada. Ramos muito finos, flexíveis e longos, ideais para trançados e cestaria. Flores pequenas, dispostas em amentilhos (inflorescências alongadas), com floração no início da primavera. Planta dióica (flores masculinas e femininas em indivíduos diferentes). Sistema radicular denso e superficial, com boa capacidade de fixação em solos úmidos. Em Argentina é da famílina de árvores conhecidas como 'sauces'" ;
     bim:mês.de.floração    "setembro a novembro" ;
     bim:bioma    "Mata Atlântica" ;
     bim:apta.para.calçada    "Não" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

