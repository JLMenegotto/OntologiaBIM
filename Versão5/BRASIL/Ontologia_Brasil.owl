ObjectProperty: bim:é.abastecedor.de
	SubPropertyOf: bim:p.abastecer
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a abastecer: é.abastecedor.de"@pt
	Annotations: bim:Chave "d.abast.100"
	Annotations: bim:Ação "Ação de abastecer"@pt
	Annotations: bim:Definição "Declara que é um elemento que abastece a algum outro elemento."@pt
	Annotations: bim:Definición "Declara que es un elemento que suministra a otro elemento."@es
	Annotations: bim:Definition "It declares that it is an element that supplies some other element."@en
	Characteristics: Irreflexive
	InverseOf: bim:é.abastecido.por

