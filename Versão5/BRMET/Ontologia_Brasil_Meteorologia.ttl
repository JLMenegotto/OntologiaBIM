bim:Esquema.TN rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:ConexĂ”es.de.EE ;
      rdfs:label  "Esquema TN"@pt ;
      bim:DefiniĂ§ĂŁo   "Consultar Norma NBR 5410. Ponto da alimentaĂ§ĂŁo diretamente aterrado, sendo as massas ligadas a esse ponto atravĂ©s de condutores de proteĂ§ĂŁo. SĂŁo consideradas trĂȘs variantes de esquema TN, de acordo com a disposiĂ§ĂŁo do condutor neutro e do condutor de proteĂ§ĂŁo: esquema TN-S, o condutor neutro e o condutor de proteĂ§ĂŁo sĂŁo distintos; esquema TN-C-S, as funĂ§Ă”es de neutro e de proteĂ§ĂŁo sĂŁo combinadas em um Ășnico condutor; esquema TN-C, as funĂ§Ă”es de neutro e de proteĂ§ĂŁo sĂŁo combinadas em um Ășnico condutor, na totalidade do esquema."@pt ;
      bim:DefiniciĂłn  "Consulte la norma NBR 5410. El punto de suministro estĂĄ directamente conectado a tierra, con las masas conectadas a este punto por conductores de protecciĂłn. Se consideran tres variantes del esquema TN, de acuerdo con la disposiciĂłn del conductor neutro y el conductor de protecciĂłn: esquema TN-S, el conductor neutro y el conductor de protecciĂłn son distintos; Las funciones de esquema, neutro y protecciĂłn de TN-C-S se combinan en un solo conductor; En el esquema TN-C, las funciones de neutro y protecciĂłn se combinan en un solo conductor en todo el esquema."@es ;
       bim:Definition  "Consult NBR 5410 Standard. The point of the supply is directly grounded, with the masses connected to this point by protective conductors. Three variants of TN scheme are considered, according to the arrangement of the neutral conductor and the protective conductor: TN-S scheme, the neutral conductor and the protective conductor are distinct; TN-C-S scheme, neutral and protection functions are combined in a single conductor; In the TN-C scheme, the neutral and protection functions are combined in a single conductor in the entire scheme."@en ;
      bim:Natureza    "Redes"@pt ;
      bim:EspĂ©cie     "Redes ElĂ©tricas"@pt ;
      bim:Tema        "ConexĂ”es de EE"@pt ;
      bim:Disciplina  "Interdisciplinar"@pt ;
      bim:Chave       "Key-METEO-382"@pt ;
      bim:CatRevit    "[ OST_ElecDistributionSys ]"   ;
      bim:ClasseIfc   "[ IfcDistributionSystemCATENARY_SYSTEM ]"    .


