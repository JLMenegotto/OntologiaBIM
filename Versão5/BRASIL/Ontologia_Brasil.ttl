bim:Cabrestante rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Amarrações ;
      rdfs:label  "Cabrestante"@pt ;
      bim:Definição   "Dispositivo mecânico motorizado usado para aplicar uma carga de tensionamento aos cabos de amarração para melhorar a estabilidade da embarcação."@pt ;
      bim:Definición  "Un dispositivo mecánico motorizado utilizado para aplicar una carga de tensión a las líneas de amarre para mejorar la estabilidad de la embarcación."@es ;
