     bim:é.ordem.botânica    bim:Rosales ;
     bim:é.família.botânica    bim:Moraceae ;
     bim:é.código.de.conservação    bim:Pouco.Preocupante ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:nome.científico    "Ficus clusiifolia" ;
     bim:tipo.botânico    "Árvore" ;
     bim:diâmetro.do.tronco   60 ;
     bim:diâmetro.mínimo.da.copa   0 ;
     bim:diâmetro.máximo.da.copa   0 ;
     bim:altura.mínima.da.planta   0 ;
     bim:altura.máxima.da.planta   0 ;
     bim:tipo.de.raiz    "Superficial" ;
     bim:profundidade.da.raiz    "1.0" ;
     bim:tempo.de.crescimento    "0 anos" ;
     bim:longevidade.da.planta    "0 anos" ;
     bim:usada.para    "Sombra e fauna" ;
     bim:descrição    "Árvore nativa do Brasil, ocorrendo em diversos biomas como a Mata Atlântica, Cerrado, Amazônia e Pantanal. Ela é notável por seu comportamento hemiepífito, muitas vezes germina sobre outras árvores ou estruturas como muros e pedras, desenvolvendo raízes que crescem até o solo e podem envolver ou até sufocar o hospedeiro. Pode atingir até 18 metros, com copa frondosa e densa, tronco curto e raízes aéreas. Folhas verdes, ovais a elípticas, coriáceas e brilhantes. Frutos: Figos vermelhos, globosos, muito apreciados por aves. Hemiepífita estranguladora, cresce sobre outra planta ou estrutura e, ao alcançar o solo, suas raízes se expandem e podem sufocar o hospedeiro" ;
     bim:mês.de.floração    "-" ;
     bim:bioma    "Amazônia, Cerrado, Mata Atlântica e Pantanal" ;
     bim:apta.para.calçada    "Não" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

