bim:Árvore rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Flora ;
      rdfs:label  "Árvore"@pt ;
      bim:Definição   "Planta lenhosa de grande porte, com tronco único e copa elevada. Altura superior a 5 m, raiz profunda, usadas em arborização urbana. Fazem fotossíntese. Para o Serviço Florestal Brasileiro é um Hábito do indivíduo definido no Inventário Florestal Nacional."@pt ;
      bim:Definición  "Planta leñosa grande, con un solo tronco y copa elevada. Altura superior a 5 m, raíz profunda, utilizada en forestación urbana. Realizan la fotosíntesis. Para el Servicio Forestal Brasileño, es un hábito del individuo definido en el Inventario Forestal Nacional."@es ;
       bim:Definition  "Large woody plant, with a single trunk and elevated crown. Height greater than 5 m, deep root, used in urban afforestation. They photosynthesize. For the Brazilian Forest Service, it is a habit of the individual defined in the National Forest Inventory."@en ;
      bim:Natureza    "Reinos"@pt ;
      bim:Espécie     "Vegetal"@pt ;
      bim:Tema        "Flora"@pt ;
      bim:Disciplina  "Paisagística"@pt ;
      bim:Chave       "Key-PAI-7"@pt ;
      bim:CatRevit    "[ OST_Planting ]"   ;
      bim:ClasseIfc   "[ IfcGeographicElement ]"   ;
      bim:ABNT        "[ 3E.02.12 ]"    .


