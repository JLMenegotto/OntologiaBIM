bim:é.bacia.hidrográfica.escoamento   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.drenar ;
                    rdfs:domain             bim:BIM ;
                    rdfs:label              "Propriedade destinada a drenar: é.bacia.hidrográfica.escoamento" ;
                    bim:Chave               "d.drenar.101" ;
                    bim:Ação                "Ação de drenar" ;
                    bim:Definição           "Declara a razão entre o volume de água escoado superficialmente e o volume de água de chuva. Coef = Vescoado / Vprecipitado, ou seja, valores próximos de 0 indicam alta infiltração. "@pt ;
                    bim:Definición          "Declara la proporción entre el volumen de escorrentía superficial y el volumen de agua de lluvia. Coef = Vescoado / Vprecipitate, es decir, valores cercanos a 0 indican una alta infiltración."@es ;bim:Definition          "Declares the ratio of the volume of surface water runoff to the volume of rainwater. Coef = Vescoado / Vprecipitate, i.e., values close to 0 indicate high infiltration."@en ;
                    owl:equivalentProperty  bim:é.bacia.hidrográfica.runoff  .


bim:d.drenar   rdf:type  owl:DatatypeProperty ;
                    rdfs:subPropertyOf      bim:BIMData  .


