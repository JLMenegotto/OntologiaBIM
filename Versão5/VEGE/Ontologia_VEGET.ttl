     bim:código    "LC" ;
     bim:descrição    "Declara que a ameaça de extinção da espécie é pouco preocupante (LC) de acordo com a Lista Vermelha da União Internacional para a Conservação da Natureza e dos Recursos Naturais (IUCN) das espécies ameaçadas." ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Dados.Deficientes  rdf:type  owl:NamedIndividual , bim:Conservação.Vegetal ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:código    "DD" ;
     bim:descrição    "Declara que há dados deficientes (DD) para verificar o perigo de extinção da espécie de acordo com a Lista Vermelha da União Internacional para a Conservação da Natureza e dos Recursos Naturais (IUCN) das espécies ameaçadas." ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Não.Avaliado  rdf:type  owl:NamedIndividual , bim:Conservação.Vegetal ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:código    "NE" ;
     bim:descrição    "Declara que o perigo de extinção da espécie não foi avaliado (NE) de acordo com a Lista Vermelha da União Internacional para a Conservação da Natureza e dos Recursos Naturais (IUCN) das espécies ameaçadas." ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

