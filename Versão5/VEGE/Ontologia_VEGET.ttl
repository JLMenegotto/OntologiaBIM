bim:Agua.em.Chafariz rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Águas.Ornamentais ;
      rdfs:label  "Agua em Chafariz"@pt ;
      bim:Definição   "Elemento paisagístico ornamental que utiliza água em movimento para criar efeitos visuais, sonoros e sensoriais em jardins, praças e espaços públicos"@pt ;
      bim:Definición  "Elemento paisajístico ornamental que utiliza el agua en movimiento para crear efectos visuales, sonoros y sensoriales en jardines, plazas y espacios públicos"@es ;
       bim:Definition  "Ornamental landscape element that uses moving water to create visual, sound and sensory effects in gardens, squares and public spaces"@en ;
