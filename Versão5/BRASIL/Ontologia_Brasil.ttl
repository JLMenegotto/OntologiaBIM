	  rdfs:label "Observações: Conceitos de elementos de municípios do Brasil"@pt ;
	  rdfs:label "DataHora: 02/07/2026 17:14:20"@pt ;
	  rdfs:label "Advertência: Traduções ao espanhol e ao inglês incorporadas - As traduções devem ser constantemente revisadas"@pt ;
	  rdfs:label "Aviso: Traducciones integradas al español e inglés - Las traducciones deben revisarse constantemente"@es ;
	  rdfs:label "Alert: Built-in Spanish and English Translations - Translations must be constantly reviewed"@en ;
	  rdfs:label "Prédio: -"@pt ;
	  rdfs:label "Cidade: -"@pt ;
	  rdfs:label "Fonte: IBGE. Diretoria de Pesquisas - DPE -  Coordenação de População e Indicadores Sociais - COPIS."@pt ;
	  rdfs:label "Explicação: Formalizar conceitos de elementos de municípios do Brasil."@pt ;
	  rdfs:label "Explicación: Formalizar conceptos de elementos de ciudades del Brasil."@es ;
	  rdfs:label "Explanation: Formalize concepts of elements of municipalities in Brazil."@en .

rdf:PlainLiteral        rdf:type  rdfs:Datatype .
rdfs:Literal            rdf:type  rdfs:Datatype .
xsd:boolean             rdf:type  rdfs:Datatype .
xsd:date                rdf:type  rdfs:Datatype .
xsd:dateTime            rdf:type  rdfs:Datatype .
xsd:dayTimeDuration     rdf:type  rdfs:Datatype .
xsd:decimal             rdf:type  rdfs:Datatype .
xsd:double              rdf:type  rdfs:Datatype .
xsd:duration            rdf:type  rdfs:Datatype .
xsd:gDay                rdf:type  rdfs:Datatype .
xsd:gMonth              rdf:type  rdfs:Datatype .
xsd:gYear               rdf:type  rdfs:Datatype .
xsd:integer             rdf:type  rdfs:Datatype .
xsd:string              rdf:type  rdfs:Datatype .
xsd:nonNegativeInteger  rdf:type  rdfs:Datatype .
xsd:time                rdf:type  rdfs:Datatype .

bim:BIM	 rdf:type  owl:Class ;            
	 rdfs:label "Raiz de Classes."@pt .

bim:BIMProp	 rdf:type  owl:ObjectProperty ;   
	 rdfs:label "Raiz de Propriedades. As propriedades de objetos e dados atualmente presentes na ontologia são apenas parte das propriedades. O arquivo Excel de propriedades contem todas as propriedades de objetos e dados planejadas para uso. A participação de uma propriedade na ontologia dependerá se foi incorporada a algum indivíduo da ontologia."@pt .

bim:BIMData	 rdf:type  owl:DatatypeProperty ; 
	 rdfs:label "Raiz de Dados. As propriedades de objetos e dados atualmente presentes na ontologia são apenas parte das propriedades. O arquivo Excel de propriedades contem todas as propriedades de objetos e dados planejadas para uso. A participação de uma propriedade na ontologia dependerá se foi incorporada a algum indivíduo da ontologia."@pt .

