bim:é.resistência.térmica   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.energizar ;
                    rdfs:domain             bim:BIM ;
                    rdfs:label              "Propriedade destinada a energizar: é.resistência.térmica" ;
                    bim:Chave               "d.energizar.115" ;
                    bim:Ação                "Ação de energizar" ;
                    bim:Definição           "Declara a capacidade de um material resistir à passagem de calor. Expressado em m²·K/W. A maior resistência melhor isolamento. "@pt ;
                    bim:Definición          "Declara la capacidad de un material para resistir el paso del calor. Expresado en m²· K/W. Cuanto mayor sea la resistencia, mejor aislamiento."@es ;bim:Definition          "Declares the ability of a material to resist the passage of heat. Expressed in m²· K/W. The higher resistance better insulation."@en ;
                    owl:inverseOf           bim:é.transmitância.térmica  .


bim:d.energizar   rdf:type  owl:DatatypeProperty ;
                    rdfs:subPropertyOf      bim:BIMData  .


bim:resistência.térmica   rdf:type  owl:DatatypeProperty ;
