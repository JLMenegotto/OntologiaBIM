	Facts: bim:é.dentro.de  bim:Brasil
	Facts: bim:é.dentro.de  bim:SP
	Facts: bim:nome  "Porto de Santos"
	Facts: bim:descrição  "Maior porto público da América Latina, com 142,8 milhões de toneladas em 2025. É multipropósito, líder em contêineres, além de operar grãos, celulose e granéis líquidos. Conecta-se ao maior parque industrial do país e possui forte integração rodoviária e ferroviária. "
	Facts: bim:categoria.revit  "[ OST_SpecialityEquipment ]"
	Facts: bim:classe.ifc  "[ IfcMarineFacilityPORT ]"
	Facts: bim:tema  "Brasil"
	Facts: bim:subtema  "Cidades"

