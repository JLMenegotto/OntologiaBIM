bim:Jardim.Informal rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Jardins ;
      rdfs:label  "Jardim Informal"@pt ;
      bim:Definição   "Jardim assimétrico, com formas orgânicas e vegetação mais livre. Inspiração naturalista (inglesa ou tropical). Promove a biodiversidade e o senso de naturalidade"@pt ;
      bim:Definición  "Jardín asimétrico, con formas orgánicas y vegetación más libre. De inspiración naturalista (inglés o tropical). Favorece la biodiversidad y la sensación de naturalidad"@es ;
       bim:Definition  "Asymmetrical garden, with organic shapes and freer vegetation. Naturalistic inspiration (English or tropical). Promotes biodiversity and a sense of naturalness"@en ;
