	Annotations: bim:CatRevit "[ OST_Mass ]"
	Annotations: bim:ClasseIfc "[ IfcBuildingElementProxy ]"
	SubClassOf: bim:Aeródromos


Class: bim:Heliporto
	Annotations: rdfs:label "Heliporto"@pt
	Annotations: bim:Definição "Um Heliporto deve estar preparado para operar helicópteros com infraestrutura de pista de pouso, hangares, abastecimento, sala de embarque, controle de tráfego aéreo, manutenção, segurança e logística."@pt
	Annotations: bim:Definición "Un helipuerto debe estar preparado para operar helicópteros con infraestructura de pista de aterrizaje, hangares, abastecimiento de combustible, sala de embarque, control de tráfico aéreo, mantenimiento, seguridad y logística."@es
	Annotations: bim:Definition "A Heliport must be prepared to operate helicopters with airstrip infrastructure, hangars, fueling, departure lounge, air traffic control, maintenance, security and logistics."@en
	Annotations: bim:Natureza "Infraestruturas"@pt
