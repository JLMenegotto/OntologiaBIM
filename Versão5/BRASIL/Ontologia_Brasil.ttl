     bim:nome    "Porto Vila do Conde" ;
     bim:descrição    "Importante para a logística da região Norte, movimentação de bauxita, alumina e grãos. Perto de corredores hidroviários, é estratégico para as exportações da Amazônia." ;
     bim:categoria.revit    "[ OST_SpecialityEquipment ]" ;
