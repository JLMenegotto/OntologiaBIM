     bim:é.código.de.conservação    bim:Pouco.Preocupante ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:nome.científico    "Corypha umbraculifera" ;
     bim:tipo.botânico    "Palmeira" ;
     bim:diâmetro.do.tronco   130 ;
     bim:diâmetro.mínimo.da.copa   3 ;
     bim:diâmetro.máximo.da.copa   5 ;
     bim:altura.mínima.da.planta   20 ;
     bim:altura.máxima.da.planta   30 ;
     bim:tipo.de.raiz    "Fascicular (cabeleira)" ;
     bim:profundidade.da.raiz    "1 até 3 m" ;
     bim:tempo.de.crescimento    "7 anos" ;
     bim:longevidade.da.planta    "80 anos" ;
     bim:usada.para    "Ornamental em parques urbanos" ;
     bim:descrição    "Tronco esguio com folhas palmadas em leque, com até 5 m de envergadura. Também é chamada de palmeira-parasol ou palma de Ceilão. Após floração deve ser monitorada por especialistas, pois pode apresentar risco de queda" ;
     bim:mês.de.floração    "Monocárpica, floresce uma única vez após 60 a 80. Após a floração, entra em senescência e as folhas secam o tronco perde vigor e a planta morre. Nessa época, produz milhões de frutos esféricos. O evento pode ser apreciado no aterro do Flamengo em Novembro de 2025, pois as palmeiras plantadas há mais de 60 anos pelo paisagista Roberto Burle Marx finalmente revelaram o seu espetáculo mais grandioso" ;
     bim:bioma    "Cultivada" ;
     bim:apta.para.calçada    "Não" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

