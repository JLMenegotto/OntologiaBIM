bim:é.fator.fotoenergético   rdf:type  owl:ObjectProperty ;
                    rdfs:subPropertyOf      bim:p.energizar ;
                    rdfs:domain             bim:BIM ;
                    rdfs:label              "Propriedade destinada a energizar: é.fator.fotoenergético" ;
                    bim:Chave               "d.energizar.110" ;
                    bim:Ação                "Ação de energizar" ;
                    bim:Definição           "Declara a quantidade de energia solar que atravessa o vidro em relação à energia solar que incide sobre ele. Expressado entre 0 a 1. Quanto menor é o valor menos energia atravessa. Equivalente a fator solar. "@pt ;
                    bim:Definición          "Declara la cantidad de energía solar que pasa a través del vidrio en relación con la energía solar que cae sobre él. Expresado entre 0 y 1. Cuanto menor sea el valor, menos energía pasará. Equivalente al factor solar."@es ;bim:Definition          "Declares the amount of solar energy that passes through the glass in relation to the solar energy that falls on it. Expressed between 0 to 1. The lower the value, the less energy it passes through. Equivalent to solar factor."@en ;
                    owl:equivalentProperty  bim:é.fator.solar  .


bim:d.energizar   rdf:type  owl:DatatypeProperty ;
                    rdfs:subPropertyOf      bim:BIMData  .


