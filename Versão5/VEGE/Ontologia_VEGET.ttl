bim:Fungos  rdf:type  owl:NamedIndividual , bim:Fungo ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Refere se ao conjunto do reino Fungi. Incluem cogumelos, bolores e leveduras. São heterotróficos, ou seja, não fazem fotossíntese e obtêm energia por decomposição" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Briófita  rdf:type  owl:NamedIndividual , bim:Divisão.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Plantas pequenas e simples, sem vasos condutores, como musgos e hepáticas. Vivem em ambientes úmidos e não produzem sementes nem flores. São as plantas terrestres mais primitivas, importantes para a retenção de água no solo e como indicadores ambientais" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Angiosperma  rdf:type  owl:NamedIndividual , bim:Divisão.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Plantas que produzem flores e frutos com sementes. Representam o grupo mais diverso do Reino Plantae, incluindo árvores, arbustos, ervas e gramíneas. Exemplos: roseiras, mangueiras, milho" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Gimnosperma  rdf:type  owl:NamedIndividual , bim:Divisão.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Plantas que produzem sementes nuas, ou seja, não envoltas por frutos. Não têm flores. Exemplos: pinheiros e ciprestes" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Licófita  rdf:type  owl:NamedIndividual , bim:Divisão.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Plantas vasculares primitivas, com vasos condutores, mas sem sementes. São semelhantes às samambaias, mas com estrutura mais simples. Exemplo: Selaginella" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Samambaia  rdf:type  owl:NamedIndividual , bim:Divisão.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Plantas chamadas de pteridófitas. São plantas vasculares que não produzem sementes. Reproduzem se por esporos e têm folhas geralmente grandes e recortadas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Liliopsida  rdf:type  owl:NamedIndividual , bim:Classe.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Sementes com um cotilédone. Folhas com nervuras paralelas, com raízes geralmente fasciculadas (cabeleiras) flores com peças florais em múltiplos de 3. Exemplos: gramíneas, orquídeas, palmeiras, lírios. Muitas espécies são cultivadas para alimentação (como arroz, milho e trigo) ou ornamentação" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Magnoliopsida  rdf:type  owl:NamedIndividual , bim:Classe.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Sementes com dois cotilédones. Folhas com nervuras reticuladas (em rede). Raízes geralmente pivotantes (com raiz principal). Flores com peças florais em múltiplos de 4 ou 5. Exemplo de plantas: feijão, soja, girassol, roseiras. Importância: Inclui grande parte das plantas alimentícias, medicinais e ornamentais" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Pinopsida  rdf:type  owl:NamedIndividual , bim:Classe.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Sementes nuas e sem frutos. Folhas geralmente aciculadas (em forma de agulha). Presença de estróbilos (cones) como estruturas reprodutivas. Exemplo de plantas: pinheiros, ciprestes, araucárias. Importância: Muitas espécies são utilizadas na produção de madeira, papel e resinas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Aquifoliales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui cinco famílias. A mais conhecida é a Aquifoliaceae, que inclui o gênero Ilex (os azevinhos). As espécies dessa ordem são majoritariamente arbustos ou árvores pequenas, com folhas coriáceas e frutos do tipo drupa." ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Arecales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui as palmeiras. São monocotiledôneas lenhosas com folhas grandes e inflorescências protegidas por espatas. Produzem frutos como coco, palmito e tâmaras" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Asparagales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui herbáceas como lírios, cebolas, alhos e orquídeas. Possuem flores com seis tépalas e sementes com fitomelanina. É a segunda ordem mais importante economicamente entre as monocotiledôneas. " ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Asterales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui a família Asteraceae, a maior entre as angiospermas. Suas flores são compostas em capítulos, como girassol, margarida e camomila. Importantes para polinizadores e medicina" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Boraginales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui ervas, arbustos e árvores com folhas alternas e flores vistosas, muitas vezes dispostas em inflorescências escorpioides. A família mais representativa é Boraginaceae, conhecida por espécies como o 'confrei' e o 'não te esqueças de mim'" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Brassicales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui mais de 4.000 espécies, muitas delas com importância econômica, como couve, mostarda, papaia e moringa. Uma característica de esta ordem é a produção de compostos de glucosinolato, conhecidos como 'óleos de mostarda'" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Caryophyllales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui diversas plantas como beterraba, cactos e amaranto. Muitas têm pigmentos betalaínicos em vez de antocianinas. Adaptadas a ambientes áridos e salinos" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Celastrales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui arbustos e árvores como Celastraceae. Possuem folhas simples, frutos cápsulas ou drupas, e são comuns em florestas tropicais e temperadas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Cucurbitales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui trepadeiras e herbáceas com flores unissexuais, pentâmeras como as abóbora, melancia e begônias. Muitas são trepadeiras com frutos comestíveis ou flores ornamentais" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Ericales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui plantas como chá (Camellia), mirtilo, azaleia e caju. Muitas têm folhas coriáceas e flores vistosas. Importantes na horticultura e alimentação" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Fabales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui as leguminosas (Fabaceae), como feijão, soja e ervilha. Fixam nitrogênio no solo por simbiose com bactérias. Frutos em forma de vagem" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Gentianales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui famílias como Apocynaceae e Rubiaceae. Muitas espécies têm látex e flores vistosas. Algumas são medicinais, como a quina e o jasmim" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Lamiales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui plantas como lavanda, alecrim, manjericão e ipê. Muitas têm folhas aromáticas e flores bilabiadas. Importantes na culinária e paisagismo" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Laurales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui árvores aromáticas como canela e louro (Lauraceae). Possuem folhas simples e flores pequenas. Comuns em florestas tropicais úmidas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Lecythidales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui árvores tropicais como a castanheira-do-pará. Árvores de grande porte, arbustos ou lianas com folhas simples, alternas, geralmente sem estípulas. nervação peninérvea. Flores grandes, vistosas, bissexuais, com simetria radial ou bilateral. inflorescências racemosas ou paniculadas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Magnoliales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui flores grandes e numerosas peças florais como magnólias e anonáceas. Representa formas primitivas de angiospermas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Malpighiales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui Euphorbiaceae, Clusiaceae, Passifloraceae e outras. Grande diversidade morfológica e ecológica" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Malvales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui plantas com flores vistosas, geralmente com pétalas livres e estames numerosos. Muitas possuem mucilagem e tricomas estrelados (hibiscos, algodoeiros), Bombacaceae (baobás), Sterculiaceae. Têm importância econômica para a produção de fibras (algodão), madeira, e óleos. São ornamentais" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Myrtales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui flores geralmente com ovário ínfero, hipanto bem desenvolvido, estames numerosos. Folhas simples e aromáticas (goiaba, eucalipto, cravo da índia), Melastomataceae, Onagraceae. Frutas tropicais, óleos essenciais, madeira" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Pandanales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui cinco famílias botânicas, com espécies que vão de ervas saprófitas a árvores tropicais, distribuídas principalmente em regiões pantropicais. Ela é reconhecida por sistemas modernos de classificação como o APG III e inclui plantas com grande diversidade morfológica e ecológica." ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Pinales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui as coníferas, plantas gimnospermas com folhas aciculares ou escamiformes, sementes nuas em cones (pinheiros e ciprestes). Madeira, resinas, papel, paisagismo" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Poales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui plantas monocotiledôneas de famílias como Poaceae (gramíneas), Bromeliaceae (bromélias) e Cyperaceae (cipós e juncos). Reúne cerca de 20 mil espécies distribuídas em 16 famílias reconhecidas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Proteales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui plantas com flor que reúne famílias botânicas distintas, como Proteaceae, Platanaceae, Nelumbonaceae e Sabiaceae, com ampla distribuição geográfica e diversidade morfológica" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Rosales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui diversidade morfológica de flores geralmente com cinco pétalas, folhas compostas ou simples (rosas, maçãs, morangos, figueiras, amoreiras). Frutas, ornamentais, madeira" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Santalales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui muitas espécies de hemiparasitas, com raízes modificadas para absorver nutrientes de outras plantas. Flores pequenas e pouco vistosas (sândalo e ervas de passarinho). Óleos aromáticos, ornamentais, ecologia de parasitismo vegetal" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Sapindales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui árvores e arbustos com folhas compostas, flores pequenas, muitas vezes com disco nectarífero. Frutos variados (lichia, guaraná, laranja, limão, manga, caju). Frutas tropicais, óleos essenciais, madeira" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Solanales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui cerca de 5 famílias botânicas. Flores bissexuais com cinco pétalas fundidas (corola simpétala), folhas alternas ou opostas, geralmente simples e sem estípulas. Frutos variados, como bagas, cápsulas ou drupas. Floema interno e sementes com testa lisa. Simetria floral geralmente radial (actinomorfa), podendo ser ligeiramente bilateral (zigomorfa)" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Zingiberales  rdf:type  owl:NamedIndividual , bim:Ordem.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:descrição    "Inclui flores vistosas, simétricas, com labelo como o gengibre, cúrcuma, helicônia. São plantas tropicais com rizomas aromáticos e flores atrativas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Anacardiaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Arbustos e árvores" ;
     bim:descrição    "Inclui muitas espécies de hemiparasitas, com raízes modificadas para absorver nutrientes de outras plantas. Flores pequenas e pouco vistosas (sândalo e ervas de passarinho). Óleos aromáticos, ornamentais, ecologia de parasitismo vegetal. Frutíferas tropicais, muitas com resina aromática" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Annonaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Arbustos e árvores" ;
     bim:descrição    "Inclui flores grandes e numerosas peças florais. Representa formas primitivas de angiospermas. Plantas tropicais, com folhas aromáticas e frutos comestíveis" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Apocynaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Arbustos, árvores e lianas" ;
     bim:descrição    "Inclui muitas espécies que têm látex e flores vistosas. Algumas são medicinais, como a quina e o jasmim Látex branco, flores vistosas, algumas tóxicas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Aquifoliaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Arbustos e árvores" ;
     bim:descrição    "Inclui árvores e arbustos dioicos, com folhas coriáceas e frutos do tipo drupa. Seu gênero mais representativo é Ilex, que inclui a erva-mate (Ilex paraguariensis) e o azevinho europeu (Ilex aquifolium)." ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Araucariaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Árvores coníferas" ;
     bim:descrição    "Inclui as coníferas, plantas gimnospermas com folhas aciculares ou escamiformes, sementes nuas em cones (pinheiros e ciprestes). Madeira, resinas, papel, paisagismo. Coníferas tropicais, gimnospermas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Arecaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Palmeiras" ;
     bim:descrição    "Inclui as palmeiras. São monocotiledôneas lenhosas com folhas grandes e inflorescências protegidas por espatas. Produzem frutos como coco, palmito e tâmaras. Palmeiras com folhas em leque ou pena" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Asparagaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Arbustos, ervas e lianas" ;
     bim:descrição    "Inclui plantas da ordem de monocotiledôneas herbáceas como lírios, cebolas, alhos e orquídeas. Possuem flores com seis pétalas e sementes com fitomelanina. É a segunda ordem mais importante economicamente entre as monocotiledôneas. Herbáceas e suculentas, são resistentes à seca" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Asteraceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Arbustos e ervas" ;
     bim:descrição    "Inclui a família Asteraceae, a maior entre as angiospermas. Suas flores são compostas em capítulos, como girassol, margarida e camomila. Importantes para polinizadores e medicina Maior família de angiospermas, flores compostas" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

bim:Begoniaceae  rdf:type  owl:NamedIndividual , bim:Família.Botânica ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:tipo.botânico    "Arbustos e árvores" ;
     bim:descrição    "Inclui herbáceas ornamentais com folhas assimétricas e flores pequenas como as begonias" ;
