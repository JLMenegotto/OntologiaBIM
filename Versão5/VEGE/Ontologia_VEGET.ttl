bim:Agua.em.Espelho rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Águas.Ornamentais ;
      rdfs:label  "Agua em Espelho"@pt ;
      bim:Definição   "Elemento paisagístico ornamental de água rasa e calma, geralmente decorativa. Pode incluir plantas aquáticas, peixes ou esculturas. Refresca o ambiente e reflete o ambiente, ampliando a paisagem"@pt ;
      bim:Definición  "Un elemento paisajístico ornamental de aguas poco profundas y tranquilas, generalmente decorativo. Puede incluir plantas acuáticas, peces o esculturas. Refresca el entorno y refleja el entorno, ampliando el paisaje"@es ;
       bim:Definition  "An ornamental landscape element of shallow and calm water, usually decorative. It can include aquatic plants, fish, or sculptures. Refreshes the environment and reflects the environment, enlarging the landscape"@en ;
      bim:Natureza    "Paisagístico"@pt ;
      bim:Espécie     "Composição Paisagística"@pt ;
      bim:Tema        "Águas Ornamentais"@pt ;
      bim:Disciplina  "Paisagística"@pt ;
      bim:Chave       "Key-PAI-52"@pt ;
      bim:CatRevit    "[ ]"   ;
      bim:ClasseIfc   "[ IfcGeographicElement ]"   ;
      bim:ABNT        "[ 3E.02.12 ]"    .


