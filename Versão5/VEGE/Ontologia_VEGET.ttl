bim:Jacarandá.de.minas  rdf:type  owl:NamedIndividual , bim:Árvore ;
     bim:é.divisão.botânica    bim:Angiosperma ;
     bim:é.classe.botânica    bim:Magnoliopsida ;
     bim:é.ordem.botânica    bim:Fabales ;
     bim:é.família.botânica    bim:Fabaceae ;
     bim:é.código.de.conservação    bim:Em.Perigo ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:nome.científico    "Machaerium villosum" ;
     bim:tipo.botânico    "Árvore" ;
     bim:diâmetro.do.tronco   50 ;
     bim:diâmetro.mínimo.da.copa   5 ;
     bim:diâmetro.máximo.da.copa   10 ;
     bim:altura.mínima.da.planta   10 ;
     bim:altura.máxima.da.planta   25 ;
     bim:tipo.de.raiz    "Pivotante" ;
     bim:profundidade.da.raiz    "0" ;
     bim:tempo.de.crescimento    "10 anos" ;
     bim:longevidade.da.planta    "mais de 80 anos" ;
     bim:usada.para    "Madeira e reflorestamento" ;
     bim:descrição    "Árvore conhecida como Jacarandá paulista ou caroba, tem madeira escura e folhas compostas. Utilizada para reflorestamento e arborização urbana. De crescimento rápido, natural de Minas Gerais até Rio Grande do Sul. Pouco agressiva, de porte médio e extremamente ornamental pela sua floração rósea. Indicada para calçadas sem fiação elétrica. Planta decídua, heliófita, pioneira (capaz de recuperação ecológica de áreas degradadas). É característica de encostas rochosas da floresta latifoliada e transição para o cerrado (https://www.ibflorestas.org.br)" ;
     bim:mês.de.floração    "setembro a novembro" ;
     bim:bioma    "Cerrado" ;
     bim:apta.para.calçada    "Não" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

