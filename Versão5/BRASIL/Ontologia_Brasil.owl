ObjectProperty: bim:é.resistência.térmica
	SubPropertyOf: bim:p.energizar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a energizar: é.resistência.térmica"@pt
	Annotations: bim:Chave "d.energ.115"
	Annotations: bim:Ação "Ação de energizar"@pt
	Annotations: bim:Definição "Declara a capacidade de um material resistir à passagem de calor. Expressado em m²·K/W. A maior resistência melhor isolamento."@pt
	Annotations: bim:Definición "Declara la capacidad de un material para resistir el paso del calor. Expresado en m²· K/W. Cuanto mayor sea la resistencia, mejor aislamiento."@es
	Annotations: bim:Definition "It declares the ability of a material to resist the passage of heat. Expressed in m²· K/W. The higher resistance better insulation."@en
	InverseOf: bim:é.transmitância.térmica

