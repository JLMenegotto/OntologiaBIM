Class: bim:Aeroporto.Doméstico
	Annotations: rdfs:label "Aeroporto.Doméstico"@pt
	Annotations: bim:Definição "Aeroporto Doméstico atendem apenas voos dentro do território nacional."@pt
	Annotations: bim:Definición "El aeropuerto nacional solo sirve vuelos dentro del territorio nacional."@es
	Annotations: bim:Definition "Domestic Airport only serves flights within the national territory."@en
