ObjectProperty: bim:é.gerador
	SubPropertyOf: bim:p.gerar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a gerar: é.gerador"@pt
	Annotations: bim:Chave "d.gerar.100"
	Annotations: bim:Ação "Ação de gerar"@pt
	Annotations: bim:Definição "Declara o ID de Revit ou GlobalId IFC ou identificador único de objeto. Declara um objeto de geração de energia. Um painel solar ou torre eólica por exemplo."@pt
	Annotations: bim:Definición "Declara el ID de Revit o IFC GlobalId o un identificador único de objeto. Identifica un objeto de generación de energía. Por ejemplo, un panel solar o una torre eólica."@es
	Annotations: bim:Definition "It declares the Revit ID or IFC GlobalId or unique object identifier. Identifies an object of energy generation. A solar panel or wind tower for example."@en
	Annotations: bim:CatRevit "[ OST_ElectricalEquipment ]"
	Annotations: bim:ClasseIfc "[ IfcBoiler , IfcChiller , IfcElectricGenerator , IfcSolarDevice , IfcTransformer , IfcEngine ]"
	EquivalentTo: bim:é.módulo.fotovoltaico

