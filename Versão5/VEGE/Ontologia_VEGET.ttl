bim:Jardim.Formal rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Jardins ;
      rdfs:label  "Jardim Formal"@pt ;
      bim:Definição   "Jardim com arranjo simétrico e geométrico de plantas. Plantas podadas. Inspiração clássica (francês, italiano). Use bordas, linhas e lagoas reflexivas"@pt ;
      bim:Definición  "Jardín con disposición simétrica y geométrica de plantas. Plantas podadas. Inspiración clásica (francés, italiano). Utiliza bordes, filas y estanques reflectantes"@es ;
       bim:Definition  "Garden with symmetrical and geometric arrangement of plants. Pruned plants. Classical inspiration (French, Italian). Use reflective edges, lines and ponds"@en ;
