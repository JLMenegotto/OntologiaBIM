      rdfs:label  "Reinos"@pt  .


bim:Vegetal rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Reinos ;
      rdfs:label  "Vegetal"@pt  .


bim:Flora rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Vegetal ;
      rdfs:label  "Flora"@pt  .


bim:Arbóreo rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Flora ;
      rdfs:label  "Arbóreo"@pt ;
      bim:Definição   "Planta cujo crescimento pode ser conduzido para se transformar em árvore, arbusto ou trepadeira. Fazem fotossíntese."@pt ;
      bim:Definición  "Una planta cuyo crecimiento puede convertirse en un árbol, arbusto o enredadera. Realizan la fotosíntesis."@es ;
       bim:Definition  "A plant whose growth can be led to become a tree, shrub or vine. They photosynthesize."@en ;
      bim:Natureza    "Reinos"@pt ;
      bim:Espécie     "Vegetal"@pt ;
      bim:Tema        "Flora"@pt ;
      bim:Disciplina  "Paisagística"@pt ;
      bim:Chave       "Key-PAI-10"@pt ;
      bim:CatRevit    "[ OST_Planting ]"   ;
      bim:ClasseIfc   "[ IfcGeographicElement ]"   ;
      bim:ABNT        "[ 3E.02.12 ]"   ;
      owl:equivalentClass 
		[ owl:unionOf ( bim:Árvore bim:Arbusto bim:Subarbusto bim:Trepadeira
		 ) ]  .


