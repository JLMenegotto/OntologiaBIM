bim:Jardim.Zen rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Jardins ;
      rdfs:label  "Jardim Zen"@pt ;
      bim:Definição   "Jardim minimalista e contemplativo, feito de pedras ornamentais (granito, seixos, quartzito, basalto) com cascalho ou areia para cobrir o solo. Plantas xerófitas (adaptadas à seca), como suculentas e cactos. Uso de troncos, esculturas ou lanternas como pontos focais. Simetria ou assimetria controlada. Texturas contrastantes entre rochas e vegetação"@pt ;
      bim:Definición  "Jardín minimalista y contemplativo, hecho de piedras ornamentales (granito, guijarros, cuarcita, basalto) con grava o arena para cubrir el suelo. Plantas xerófitas (adaptadas a la sequía), como suculentas y cactus. Uso de troncos, esculturas o linternas como puntos focales. Simetría o asimetría controlada. Texturas contrastantes entre rocas y vegetación"@es ;
       bim:Definition  "Minimalist and contemplative garden, made of ornamental stones (granite, pebbles, quartzite, basalt) with gravel or sand to cover the ground. Xerophytic (drought-adapted) plants, such as succulents and cacti. Use of logs, sculptures, or lanterns as focal points. Symmetry or controlled asymmetry. Contrasting textures between rocks and vegetation"@en ;
      bim:Natureza    "Paisagístico"@pt ;
      bim:Espécie     "Composição Paisagística"@pt ;
      bim:Tema        "Jardins"@pt ;
      bim:Disciplina  "Paisagística"@pt ;
      bim:Chave       "Key-PAI-51"@pt ;
      bim:CatRevit    "[ ]"   ;
      bim:ClasseIfc   "[ IfcGeographicElement ]"   ;
      bim:ABNT        "[ 3E.02.12 ]"    .


