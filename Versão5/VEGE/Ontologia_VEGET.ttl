bim:Ipê.roxo  rdf:type  owl:NamedIndividual , bim:Árvore ;
     bim:é.divisão.botânica    bim:Angiosperma ;
     bim:é.classe.botânica    bim:Magnoliopsida ;
     bim:é.ordem.botânica    bim:Lamiales ;
     bim:é.família.botânica    bim:Bignoniaceae ;
     bim:é.código.de.conservação    bim:Pouco.Preocupante ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:nome.científico    "Handroanthus impetiginosus" ;
     bim:tipo.botânico    "Árvore" ;
     bim:diâmetro.do.tronco   50 ;
     bim:diâmetro.mínimo.da.copa   4 ;
     bim:diâmetro.máximo.da.copa   8 ;
     bim:altura.mínima.da.planta   6 ;
     bim:altura.máxima.da.planta   20 ;
     bim:tipo.de.raiz    "Pivotante" ;
     bim:profundidade.da.raiz    "1.5" ;
     bim:tempo.de.crescimento    "8 anos" ;
     bim:longevidade.da.planta    "mais de 60 anos" ;
     bim:usada.para    "Ornamental e madeira" ;
     bim:descrição    "Árvore de flores roxas vibrantes, muito usada em paisagismo. Conhecida também como Pau d' arco roxo, é muito ornamental. Sua madeira possui alta resistência e bastante valorizada no mercado externo, utilizada em obras, construção pesada, quilhas de navios, instrumentos musicais e vastamente utilizada para fabricação de pisos. Desbastes seletivos ocorrem entre 4 e 8 anos de idade para a produção e madeira. É resistente às geadas. (https://www.ibflorestas.org.br). Também conhecido como lapacho em Argentina" ;
     bim:mês.de.floração    "agosto a setembro" ;
     bim:bioma    "Cerrado, Mata Atlântica" ;
     bim:apta.para.calçada    "Sim" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

