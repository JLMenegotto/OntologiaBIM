bim:Arbusto rdf:type  owl:Class  ;
      rdfs:subClassOf  bim:Flora ;
      rdfs:label  "Arbusto"@pt ;
      bim:Definição   "Planta lenhosa de pequeno a médio porte, com vários caules desde a base. Altura entre 1 e 5 m, copa densa, ideal para cercas vivas e bordaduras. Fazem fotossíntese. Para o Serviço Florestal Brasileiro é um Hábito do indivíduo patrimonializado como planta."@pt ;
      bim:Definición  "Planta leñosa de tamaño pequeño a mediano, con varios tallos desde la base. Altura entre 1 y 5 m, dosel denso, ideal para setos y bordes. Realizan la fotosíntesis. Para el Servicio Forestal Brasileño, es un hábito del individuo patrimonializado como planta."@es ;
       bim:Definition  "Small to medium-sized woody plant, with several stems from the base. Height between 1 and 5 m, dense canopy, ideal for hedges and borders. They photosynthesize. For the Brazilian Forest Service, it is a habit of the patrimonialized individual as a plant."@en ;
      bim:Natureza    "Reinos"@pt ;
      bim:Espécie     "Vegetal"@pt ;
      bim:Tema        "Flora"@pt ;
      bim:Disciplina  "Paisagística"@pt ;
      bim:Chave       "Key-PAI-8"@pt ;
      bim:CatRevit    "[ OST_Planting ]"   ;
      bim:ClasseIfc   "[ IfcGeographicElement ]"   ;
      bim:ABNT        "[ 3E.02.12 ]"    .


