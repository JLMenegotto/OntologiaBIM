bim:Angico.vermelho  rdf:type  owl:NamedIndividual , bim:Árvore ;
     bim:é.divisão.botânica    bim:Angiosperma ;
     bim:é.classe.botânica    bim:Magnoliopsida ;
     bim:é.ordem.botânica    bim:Fabales ;
     bim:é.família.botânica    bim:Fabaceae ;
     bim:é.código.de.conservação    bim:Pouco.Preocupante ;
     bim:descrição    "Definição de um Indivíduo de Classe Conceitual. Não tem existência no projeto se não estiver representado por um Indivíduo da classe Projeto." ;
     bim:nome.científico    "Anadenanthera colubrina" ;
     bim:tipo.botânico    "Árvore" ;
     bim:diâmetro.do.tronco   50 ;
     bim:diâmetro.mínimo.da.copa   4 ;
     bim:diâmetro.máximo.da.copa   10 ;
     bim:altura.mínima.da.planta   8 ;
     bim:altura.máxima.da.planta   25 ;
     bim:tipo.de.raiz    "Pivotante" ;
     bim:profundidade.da.raiz    "1.5" ;
     bim:tempo.de.crescimento    "8 anos" ;
     bim:longevidade.da.planta    "mais de 60 anos" ;
     bim:usada.para    "Reflorestamento e medicinal" ;
     bim:descrição    "Árvore perenifólia, com 5 a 10 m de altura, podendo atingir até 20 m de altura e 50 cm de DAP, na idade adulta. Tronco geralmente tortuoso, com acúleos dispersos e ralos. Fuste curto com até 8 m de comprimento. Ramificação: cimosa e irregular. Copa alongada, com folhagem verde-escura, e ramos com ou sem espinhos. Casca com espessura de até 15 mm. A casca externa é acinzentada, áspera e levemente fissurada. Folhas compostas, com 3 a 4 pares de pinas, folíolo mais raquis de 6 a 15 cm de comprimento, folíolo relativamente grande de 1 a 2,5 cm de comprimento por 0,5 a 1 cm de largura, com grossa glândula séssil, orbicular na base superior do pecíolo e uma menor nos extremos raquial e pinar. Pinas com ráquis pubérulo no bordo superior, com 6 a 10 pares de folíolos.  Casca rica em taninos, usada em medicina popular. Típica dos biomas Caatinga, Cerrado e Mata Atlântica (https://www.embrapa.br)" ;
     bim:mês.de.floração    "setembro a novembro" ;
     bim:bioma    "Cerrado, Caatinga" ;
     bim:apta.para.calçada    "Sim" ;
     bim:categoria.revit    "[ OST_Planting ]" ;
     bim:classe.ifc    "[ IfcGeographicElement ]" ;
     bim:código.abnt    "[ 3E.02.12 ]"  .

