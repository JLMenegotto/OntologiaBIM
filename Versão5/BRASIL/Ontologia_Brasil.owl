ObjectProperty: bim:p.censar
	SubPropertyOf: bim:BIMProp



ObjectProperty: bim:é.população.2024
	SubPropertyOf: bim:p.censar
	domain: bim:BIM
	range: bim:Projeto
	Annotations: rdfs:label "Propriedade destinada a censar: é.população.2024"@pt
	Annotations: bim:Chave "d.censa.113"
	Annotations: bim:Ação "Ação de censar"@pt
	Annotations: bim:Definição "Declara a população do censo realizado pelo IBGE no Brasil no ano 2024. Operação censitária que atualiza a contagem de população municipais e subsidia o cálculo de suas estimativas anuais nos anos subsequentes."@pt
	Annotations: bim:Definición "Declara la población del censo realizado por el IBGE en Brasil en el año 2024. Operación censal que actualiza el recuento municipal de población y subvenciona el cálculo de sus estimaciones anuales en años posteriores."@es
	Annotations: bim:Definition "It declares the population of the census carried out by the IBGE in Brazil in the year 2024. Census operation that updates the municipal population count and subsidizes the calculation of their annual estimates in subsequent years."@en

DataProperty: bim:d.censar
	SubPropertyOf: bim:BIMData



DataProperty: bim:população.2024
	SubPropertyOf: bim:d.censar
	range: xsd:integer
	Annotations: rdfs:label "Dado para censar:  população.2024  Deve ser formatado como (xsd:integer)"@pt
	Annotations: bim:Chave "d.censa.113"
	Annotations: bim:Ação "Ação de censar"@pt
	Annotations: bim:Definição "Declara a população do censo realizado pelo IBGE no Brasil no ano 2024. Operação censitária que atualiza a contagem de população municipais e subsidia o cálculo de suas estimativas anuais nos anos subsequentes."@pt
	Annotations: bim:Definición "Declara la población del censo realizado por el IBGE en Brasil en el año 2024. Operación censal que actualiza el recuento municipal de población y subvenciona el cálculo de sus estimaciones anuales en años posteriores."@es
	Annotations: bim:Definition "It declares the population of the census carried out by the IBGE in Brazil in the year 2024. Census operation that updates the municipal population count and subsidizes the calculation of their annual estimates in subsequent years."@en

